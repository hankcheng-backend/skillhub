{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkillHub",
  "version": "0.1.0",
  "identifier": "com.skillhub.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SkillHub",
        "width": 1100,
        "height": 700
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' http://127.0.0.1:*"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hankcheng-backend/skillhub/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGQjg4NjUzMUU0M0YwMDYKUldRRzhFTWVVNGE0TDJuUWFLWjNHa2tlZ3IzUG9ZdThiQzdubkd2NUx4NVpOYjFlTG1maXZCMngK"
    }
  }
}
